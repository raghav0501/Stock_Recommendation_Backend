DATABASE_URL="postgresql://alumnus:alumnus_dev@localhost:5432/alumnus_db"
MONGODB_URI="mongodb://localhost:27017/alumnus_db"
REDIS_URL="redis://localhost:6379"

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-random-32-char-string-abc"
REFRESH_TOKEN_SECRET="another-random-32-char-secret-def"
REFRESH_TOKEN_ENCRYPTION_KEY="32characterencryptionkeyfordev!!"

# ── Firebase ─────────────────────────────────────────────────────────────────
# Omit GCP_SERVICE_ACCOUNT_PATH when deploying to Firebase Functions (uses ADC)
GCP_SERVICE_ACCOUNT_PATH="./secrets/firebase-service-account.json"
GCP_PROJECT_ID="your-firebase-project-id"
GCP_DATABASE_ID="(default)"

# ── SMTP (used for OTP emails and password resets) ────────────────────────────
# Gmail example: use an App Password, not your account password
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="noreply@alumnus.app"

# ── OTP ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters — used to HMAC-hash stored OTPs
OTP_HMAC_SECRET="change-this-to-a-random-32-char-otp-secret"
OTP_TTL_SECONDS="300"        # OTP valid for 5 minutes
OTP_COOLING_SECONDS="60"     # 1 minute between re-request attempts
